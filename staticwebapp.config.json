{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "/static/*",
      "/css/*",
      "/images/*.{png,jpg,jpeg,gif,svg,webp}",
      "/*.{css,js,ico,txt,xml,woff,woff2}"
    ]
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".mjs": "application/javascript",
    ".json": "application/json",
    ".css": "text/css",
    ".svg": "image/svg+xml"
  }
}